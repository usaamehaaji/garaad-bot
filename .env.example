# =====================================================================
# GARAAD BOT — Environment Variables
# =====================================================================
# 1. Koobiga faylkan: cp .env.example .env
# 2. TOKEN-ka bot-kaaga ku reeb halkan hoose
# 3. npm start

TOKEN=YOUR_DISCORD_BOT_TOKEN_HERE
# Railway: isku mid ah TOKEN — ama DISCORD_TOKEN / DISCORD_BOT_TOKEN

MONGO_URI=YOUR_MONGODB_URI_HERE

# Payment numbers (shown in ?payment command)
EVC_NUMBER=610917813
WAAFI_NUMBER=5291823405989205
SALAAM_BANK=38492323

# GitHub backup + su'aalaha sync (optional)
BACKUP_REPO=usaamehaaji/garaad-bot
BACKUP_TOKEN=YOUR_GITHUB_TOKEN_HERE
